generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  reviews    Review[]

  @@map("users")
}

model Review {
  id         Int      @id @default(autoincrement())
  user_id    Int
  book_title String
  rating     Int
  review     String
  mood       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}
